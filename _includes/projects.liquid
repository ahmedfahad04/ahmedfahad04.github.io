<div class="col">
  <div class="card h-100 hoverable project-showcase-card">
    <div class="card-body d-flex flex-column">
      <h2 class="card-title project-title">
        <a href="{{ project.url | relative_url }}">{{ project.title }}</a>
      </h2>

      <p class="card-text project-description">{{ project.description }}</p>

      {% if project.tech_stack %}
        <div class="project-tech-stack" aria-label="Tech stack">
          {% for tech in project.tech_stack %}
            <span class="project-tech-pill">{{ tech }}</span>
          {% endfor %}
        </div>
      {% endif %}

      <div class="project-links mt-auto">
        <a class="project-link" href="{{ project.url | relative_url }}">Details</a>

        {% if project.website %}
          <a class="project-link" href="{{ project.website }}" target="_blank" rel="external nofollow noopener">Website</a>
        {% endif %}

        {% if project.github %}
          <a class="project-link" href="{{ project.github }}" target="_blank" rel="external nofollow noopener">GitHub</a>
        {% endif %}

        {% if project.kaggle %}
          <a class="project-link" href="{{ project.kaggle }}" target="_blank" rel="external nofollow noopener">Kaggle</a>
        {% endif %}
      </div>
    </div>
  </div>
</div>
